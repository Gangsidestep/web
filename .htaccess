###################### map /http:// to https:// ####################

RewriteEngine On 
RewriteCond %{HTTP_HOST} ^www\.(.+)
RewriteCond %{HTTPS}s/%1 ^(on(s)|offs)/(.+)
RewriteRule ^ http%2://%3%{REQUEST_URI} [L,R=301]
RewriteCond %{HTTPS} off 
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteEngine On
RewriteCond %{SERVER_PORT} =443
RewriteBase /
RewriteCond %{HTTP_HOST} mydropintheoceans.org$ [NC]
RewriteRule ^(.*)$ https://mydropintheoceans.org/$1 [L,R=301]

##RewriteEngine On
RewriteCond %{SERVER_PORT} =80
RewriteCond %{HTTP_HOST} mydropintheoceans\\.org$ [NC]
RewriteRule ^(.*)$ https://mydropintheoceans.org%{REQUEST_URI} [L,R=301]

