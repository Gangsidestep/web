RewriteEngine On
# Canonical host: force www -> non-www in one hop
RewriteCond %{HTTP_HOST} ^www\.mydropintheoceans\.org$ [NC]
RewriteRule ^ https://mydropintheoceans.org%{REQUEST_URI} [R=301,L]

# Ensure favicon always resolves to the HTTPS images path to avoid mixed-content
RewriteCond %{REQUEST_URI} ^/favicon\.ico$
RewriteRule ^favicon\.ico$ https://%{HTTP_HOST}/images/favicon.ico [L,R=301]

# Retire old page: return 410 Gone to accelerate de-indexing
RewriteRule ^about-mydio(/.*)?$ - [G,L,NC]

# Redirect old blog post URLs (blog/post-name.php) to new directory format (blog/post-name/)
RewriteRule ^blog/([a-z-]+)\.php$ /blog/$1/ [R=301,L,NC]

RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Internal locale routing for multilingual URLs
# /en/... /fr/... and /de/... are rewritten to existing paths while exposing locale via APP_LOCALE
RewriteRule ^(en|fr|de)/?$ / [QSA,E=APP_LOCALE:$1,L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(en|fr|de)/(.*)$ /$2 [QSA,E=APP_LOCALE:$1,L]

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect explicit requests to /index.php to canonical /
  RewriteCond %{THE_REQUEST} \s/index\.php[?\s] [NC]
  RewriteRule ^index\.php$ / [R=301,L]

</IfModule>

# Ensure favicon requests are served (avoid 404s)
Redirect 301 /favicon.ico /images/favicon.ico
Options -Indexes

SetOutputFilter DEFLATE
AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml

<IfModule mod_expires.c>
ExpiresActive on
# cache.appcache needs re-requests in FF 3.6 (thx Remy ~Introducing HTML5)   
ExpiresByType text/cache-manifest       "access plus 0 seconds"           
# Your document html    
ExpiresByType text/html                 "access plus 0 seconds"       
# Data    
ExpiresByType text/xml                  "access plus 0 seconds"    
ExpiresByType application/xml           "access plus 0 seconds"    
ExpiresByType application/json          "access plus 0 seconds"  
# enable the directives - assuming they're not enabled globally


# send an Expires: header for each of these mimetypes (as defined by server)
ExpiresByType image/png "access plus 1 month"
ExpiresByType image/gif "access plus 1 month"
ExpiresByType image/jpeg "access plus 1 month"

# css may change a bit sometimes, so define shorter expiration
ExpiresByType text/css "access plus 1 days"

# Favicon (cannot be renamed)
  ExpiresByType image/x-icon              "access plus 1 week"

# Webfonts
ExpiresByType font/truetype "access plus 1 month"
ExpiresByType font/opentype "access plus 1 month"
ExpiresByType application/x-font-woff "access plus 1 month"

#Create filter to match files you want to cache
<Files "*.js">
    Header add "Cache-Control" "max-age=604800"
</Files>
 <IfModule mod_headers.c>
    Header append Cache-Control "public"
  </IfModule>
   
</IfModule>


###################### Redirect old URLs to current structure #################
RewriteEngine On
# Keep locale-prefixed paths active for multilingual routing
Redirect 301 /home/ https://mydropintheoceans.org/
Redirect 301 /home https://mydropintheoceans.org/
Redirect 301 /business/ https://mydropintheoceans.org/
################################################################################

######################### Howto map /~user to /user ############################
RewriteEngine On
RewriteCond %{REQUEST_URI} ^/([^/]+)$
RewriteCond %{DOCUMENT_ROOT}/%1 !-d
RewriteCond /home/sites/%{SERVER_NAME}/users/%1 -d
RewriteRule ^([^/]+)$ http://mydropintheoceans.org/$1/ [R,L]
RewriteCond %{REQUEST_URI} ^/([^/]+)/
RewriteCond %{DOCUMENT_ROOT}/%1 !-d
RewriteCond /home/sites/%{SERVER_NAME}/users/%1 -d
RewriteRule ^([^/]+)(.+)$ /~$1/$2
################################################################################

###################### Howto map /users/user to /users/user ####################
RewriteEngine On
RewriteCond %{REQUEST_URI} ^/users/([^/]+)$
RewriteCond %{DOCUMENT_ROOT}/%1 !-d
RewriteCond /home/sites/%{SERVER_NAME}/users/%1 -d
RewriteRule ^users/([^/]+)$ http://mydropintheoceans.org/users/$1/ [R,L]
RewriteCond %{REQUEST_URI} ^/users/([^/]+)/
RewriteCond %{DOCUMENT_ROOT}/%1 !-d
RewriteCond /home/sites/%{SERVER_NAME}/users/%1 -d
RewriteRule ^users/([^/]+)(.+)$ /~$1/$2
